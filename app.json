{
  "expo": {
    "name": "CBH Online",
    "slug": "cbh-youth-online-mobile",
    "version": "2.7.4",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "com.fatties.youth",
    "ios": {
      "supportsTablet": true,
      "icon": {
        "dark": "./app/assets/cbh-youth-iOS-Dark-1024x1024@1x.png",
        "light": "./app/assets/cbh-youth-iOS-Default-1024x1024@1x.png",
        "tinted": "./app/assets/cbh-youth-iOS-ClearDark-1024x1024@1x.png"
      },
      "bundleIdentifier": "com.fatties.youth",
      "buildNumber": "274",
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép CBH Youth Online truy cập camera của bạn để chụp ảnh",
        "NSPhotoLibraryUsageDescription": "Cho phép CBH Youth Online truy cập thư viện ảnh của bạn",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.fatties.youth"
            ]
          }
        ],
        "UIApplicationSceneManifest": {
          "UIApplicationSupportsMultipleScenes": false,
          "UISceneConfigurations": {}
        }
      }
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.fatties.youth",
              "host": "oauth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff",
        "monochromeImage": "./app/assets/adaptive-icon-monochrome.png"
      },
      "package": "com.fatties.youth",
      "versionCode": 274,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./app/assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "172eec8c-8c58-453c-a375-258412496e09"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/172eec8c-8c58-453c-a375-258412496e09"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./app/assets/cbh-youth-iOS-Default-1024x1024@1x.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./app/assets/cbh-youth-iOS-Dark-1024x1024@1x.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép CBH Youth Online truy cập camera của bạn",
          "microphonePermission": "Cho phép CBH Youth Online truy cập microphone của bạn",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./app/assets/notification.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "notification": {
      "icon": "./app/assets/notification.png",
      "color": "#ffffff"
    }
  }
}